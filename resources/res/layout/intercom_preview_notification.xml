<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="bottom|center_horizontal"
    android:orientation="horizontal"
    android:id="@+id/notification_root"
    android:visibility="visible"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="16dp"
    android:layout_marginRight="16dp"
    android:layout_marginHorizontal="16dp">
    <androidx.compose.p013ui.platform.ComposeView
        android:id="@+id/chat_snippet_compose_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <FrameLayout
        android:id="@+id/parent_card"
        android:background="@drawable/intercom_card_background"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">
        <LinearLayout
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp">
            <ImageView
                android:layout_gravity="top"
                android:id="@+id/preview_avatar"
                android:layout_width="@dimen/intercom_container_card_avatar_size"
                android:layout_height="@dimen/intercom_container_card_avatar_size"
                android:contentDescription="Teammate avatar"/>
            <androidx.compose.p013ui.platform.ComposeView
                android:layout_gravity="top"
                android:id="@+id/preview_avatar_compose_view"
                android:visibility="gone"
                android:layout_width="@dimen/intercom_container_card_avatar_size"
                android:layout_height="@dimen/intercom_container_card_avatar_size"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">
                <androidx.compose.p013ui.platform.ComposeView
                    android:id="@+id/ticket_header_compose_view"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textSize="16sp"
                    android:textColor="@color/intercom_black"
                    android:ellipsize="end"
                    android:id="@+id/in_app_notification_message_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="2"/>
                <TextView
                    android:textAppearance="?android:attr/textAppearanceMedium"
                    android:textSize="16sp"
                    android:textColor="@color/intercom_grey_600"
                    android:ellipsize="end"
                    android:id="@+id/reply_from_textview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
