<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/gb_dialog"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/dialog_title_size"
        android:textStyle="normal"
        android:textColor="@color/black_3"
        android:gravity="center"
        android:id="@+id/tv_permission_title"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginLeft="18dp"
        android:text="@string/downloader_tip_title"/>
    <TextView
        android:textSize="@dimen/dialog_content_size"
        android:textColor="@color/black_3"
        android:gravity="start"
        android:id="@+id/tv_permission_desc"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="40dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/downloader_without_install_permission"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/dialog_btn_size"
            android:textColor="@color/black_3"
            android:gravity="center"
            android:id="@+id/tv_permission_cancel"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:text="@string/downloader_cancel"
            android:layout_weight="1"/>
        <View
            android:background="#eeeeee"
            android:layout_width="0.5dp"
            android:layout_height="match_parent"/>
        <TextView
            android:textSize="@dimen/dialog_btn_size"
            android:textColor="@color/updater_positive_color"
            android:gravity="center"
            android:id="@+id/tv_permission_confirm"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:text="@string/downloader_setting"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
